NEXT_PUBLIC_SUPABASE_URL=https://seu-projeto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua-chave-anon-publica
SUPABASE_SERVICE_ROLE_KEY=sua-chave-service-role-apenas-no-servidor
COMMUNICATION_MODE=manual

# WhatsApp Business Platform / Cloud API
# Nunca use estas variaveis com NEXT_PUBLIC.
WHATSAPP_ACCESS_TOKEN=seu-token-permanente-da-meta
WHATSAPP_PHONE_NUMBER_ID=id-do-numero-no-whatsapp-cloud-api
WHATSAPP_API_VERSION=v23.0
WHATSAPP_WEBHOOK_VERIFY_TOKEN=crie-uma-frase-secreta-para-o-webhook

# Google Places API (New)
GOOGLE_PLACES_API_KEY=sua-chave-do-google-cloud
